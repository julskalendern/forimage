name: continius_integrations
on:
  push:
    branches: [ "main" ]
    tags:
      - 'v[0-9]+.[0-9]+.[0-9]+'
jobs:
  ci-cd:
    runs-on: self-hosted
    if: ${{ (github.ref_type == 'tag') }}
    steps:
      - uses: actions/checkout@master
      - uses: FranzDiebold/github-env-vars-action@v2
      - uses: actions/setup-python@v4

      - run: |
            python -m pip install --upgrade pip
